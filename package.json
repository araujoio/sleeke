{
  "name": "sleeke",
  "version": "1.0.2",
  "description": "Nextjs template generator",
  "author": "araujoio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/araujoio/sleeke.git"
  },
  "keywords": [
    "sleeke",
    "cli",
    "nextjs",
    "react",
    "typescript",
    "tailwind"
  ],
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "sleeke": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup --clean && tsx src/utils/copy-templates.ts",
    "start": "node dist/index.js",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test": "vitest"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "chalk": "5.6.2",
    "commander": "14.0.3",
    "execa": "9.6.1",
    "fs-extra": "11.3.4",
    "kleur": "4.1.5",
    "ora": "9.3.0",
    "prompts": "2.4.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/fs-extra": "11.0.4",
    "@types/node": "25.5.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.2",
    "rimraf": "6.1.3",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  }
}
